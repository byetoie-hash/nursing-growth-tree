# ============ The Nursing Growth Tree — Environment Variables ============
# คัดลอกไฟล์นี้เป็น .env แล้วกรอกค่าจริง (ห้ามอัปไฟล์ .env ขึ้น GitHub)

# --- Supabase (Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# --- Database (ปุ่ม Connect) ---
# Transaction pooler (port 6543) + ต่อท้าย ?pgbouncer=true&connection_limit=1
DATABASE_URL="postgresql://postgres.xxxx:รหัสผ่าน@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct/Session (port 5432)
DIRECT_URL="postgresql://postgres.xxxx:รหัสผ่าน@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres"

# --- Auth & Crypto ---
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"  ← จดสำรองไว้! ใช้เข้ารหัสข้อมูลติดต่อผู้ร้องเรียน
ENCRYPTION_KEY=""

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_HOSPITAL_NAME="กองการพยาบาล โรงพยาบาลของคุณ"
SEED_ADMIN_PASSWORD="ตั้งรหัสผ่าน admin"

# --- การแจ้งเตือน (ไม่บังคับ — เว้นว่างได้) ---
LINE_CHANNEL_ACCESS_TOKEN=""
LINE_ADMIN_USER_ID=""
RESEND_API_KEY=""
NOTIFY_EMAIL_TO=""
