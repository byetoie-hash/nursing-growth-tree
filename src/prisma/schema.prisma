// ============================================================
// The Nursing Growth Tree — Prisma Schema (PostgreSQL / Supabase)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")   // pooled (pgbouncer) สำหรับ runtime
  directUrl = env("DIRECT_URL")     // direct สำหรับ migration
}

// ---------- Enums ----------

enum Role {
  ADMIN
  USER
}

enum ComplaintStatus {
  NEW          // รับเรื่องแล้ว/กำลังตรวจสอบ — ใบไม้สีแดง
  IN_PROGRESS  // กำลังดำเนินการ/ติดตาม (รวมข้อจำกัดเชิงระบบ) — ใบไม้สีเหลือง
  RESOLVED     // ดำเนินการแก้ไขแล้วเสร็จ — ใบไม้สีเขียวเข้ม
}

// ประเภทเรื่องที่ส่งเข้า: ข้อร้องเรียน หรือ ข้อเสนอแนะ (ใช้ workflow สถานะเดียวกัน)
enum FeedbackKind {
  COMPLAINT
  SUGGESTION
}

enum PraiseCategory {
  SERVICE_BEHAVIOR // ด้านพฤติกรรมบริการ → ครบ 10 ใบ ออกดอกปีบสีขาว 1 ดอก
  GENERAL_SERVICE  // ด้านคุณภาพการบริการ → ครบ 10 ใบ ออกผลไม้ 1 ผล
}

enum ContactChannel {
  NONE
  PHONE
  LINE
  EMAIL
}

// ---------- Models ----------

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(USER)
  createdAt    DateTime @default(now())
  auditLogs    AuditLog[]
}

model Department {
  id         String      @id @default(cuid())
  name       String      @unique
  active     Boolean     @default(true) // ปิดชั่วคราวได้จากหน้าแอดมิน (ไม่ลบข้อมูลเดิม)
  complaints Complaint[]
  praises    Praise[]
}

// ค่าตั้งระบบที่แอดมินแก้ได้จากหน้าเว็บ (เช่น orgName) — ไม่ต้องแก้โค้ด/env
model Setting {
  key   String @id
  value String
}

model Complaint {
  id             String          @id @default(cuid())
  // ---- ผู้ส่ง (อาจไม่เปิดเผยตัวตน) ----
  isAnonymous    Boolean         @default(false)
  senderName     String?         // ไม่บังคับ
  // ข้อมูลติดต่อกลับถูกเข้ารหัส AES-256-GCM ก่อนบันทึกเสมอ (อ่านได้เฉพาะ Admin)
  phoneEnc       String?
  lineEnc        String?
  emailEnc       String?
  contactChannel ContactChannel  @default(NONE)
  // ---- เนื้อหา ----
  departmentId   String?
  department     Department?     @relation(fields: [departmentId], references: [id])
  category       String          // ประเภทเรื่อง
  detail         String
  incidentAt     DateTime?       // วันเวลาที่เกิดเหตุ
  attachments    String[]        // URL ไฟล์/รูปใน Supabase Storage
  // ---- สถานะ + ตำแหน่งใบไม้บนต้น ----
  kind           FeedbackKind    @default(COMPLAINT)
  status         ComplaintStatus @default(NEW)
  branchIndex    Int             // กิ่งที่ใบเกาะ (สุ่มตอนสร้าง)
  branchT        Float           // ตำแหน่งบนกิ่ง 0..1
  acknowledgedAt DateTime?       // เวลาที่ Admin รับเรื่อง
  resolvedAt     DateTime?       // เวลาที่แก้ไขเสร็จ
  adminNote      String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([status])
  @@index([createdAt])
}

model Praise {
  id           String         @id @default(cuid())
  isAnonymous  Boolean        @default(false)
  senderName   String?
  departmentId String?
  department   Department?    @relation(fields: [departmentId], references: [id])
  category     PraiseCategory
  message      String
  staffName    String?        // ชื่อเจ้าหน้าที่ที่อยากชม (ถ้ามี)
  attachments  String[]
  branchIndex  Int
  branchT      Float
  createdAt    DateTime       @default(now())

  @@index([category])
  @@index([createdAt])
}

// รางวัลที่ต้นไม้ได้รับ (ราก / ดอก / ผล) — สร้างอัตโนมัติเมื่อครบ 10
model TreeReward {
  id        String   @id @default(cuid())
  kind      String   // ROOT | FLOWER | FRUIT
  anchor    Float    // ตำแหน่งแนวนอน 0..1 บนพื้น/เรือนยอด
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String   // เช่น COMPLAINT_STATUS_CHANGED
  entity    String   // Complaint | Praise | ...
  entityId  String
  detail    String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}
